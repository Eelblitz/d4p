# Copy this file to .env and fill in your values
# Never commit .env to version control

# Django core
SECRET_KEY=your-very-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Database (leave blank to use SQLite in development)
# DATABASE_URL=postgres://user:password@localhost:5432/dm4price

# Email (leave as console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@dm4price.com

# Admin setup script
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@dm4price.com
ADMIN_PASSWORD=

# Sample data script (dev only)
SAMPLE_SELLER_USERNAME=john_seller
SAMPLE_SELLER_EMAIL=john@example.com
SAMPLE_SELLER_PASSWORD=
